<Page x:Class="NedelniNavrat.Pages.LivingRoom"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NedelniNavrat.Pages"
      mc:Ignorable="d" 
      Height="800" Width="1000"
      Title="LivingRoom">

    <Grid>

        <!-- POZADÍ (BG IMAGE) -->
        <Image Source="/img/livingroom.jpg"
           Stretch="UniformToFill"
           Panel.ZIndex="0"/>



        <Button Click="Dvere" HorizontalAlignment="Left" Margin="826,160,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.288,-0.391" Height="418" Width="104"/>
        <Button Click="VzkazObyvak"  HorizontalAlignment="Left" Height="89" Margin="468,197,0,0" VerticalAlignment="Top" Width="121" RenderTransformOrigin="0.5,0.5">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-5.038"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
        <Button Click="ZatimNic"  HorizontalAlignment="Left" Margin="160,232,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.515,0.641" Height="285" Width="84"/>
        <Button Click="Polstar"  HorizontalAlignment="Left" Margin="259,385,0,0" VerticalAlignment="Top" Height="57" Width="80"/>
        <Button Click="ZatimNic"  HorizontalAlignment="Left" Margin="626,441,0,0" VerticalAlignment="Top" Height="106" Width="114"/>
        <Button Click="Rohozka"  HorizontalAlignment="Left" Margin="789,566,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Width="88" Height="58">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="29.337"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
        <Button Click="ZatimNic"  HorizontalAlignment="Left" Margin="60,492,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.417,0.649" Height="75" Width="68">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-1.552"/>
                    <TranslateTransform X="0.478" Y="0.13"/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
        <Button Click="XXX" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Margin="0,160,0,0" VerticalAlignment="Top" Height="170" Width="99" RenderTransformOrigin="0.5,0.5">
            <Button.Style>
                <Style  TargetType="Button">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0"/>
                       <!-- <Setter Property="Cursor" Value="Hand"/> -->
                    </Trigger>
                </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

    </Grid>
</Page>
