<Window x:Class="NedelniNavrat.messages.LoadGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoadGame"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Image Source="/img/pozadi_popup.jpg"
               Stretch="UniformToFill"
               Panel.ZIndex="0"/>

        <ListBox x:Name="SaveList"
                 Margin="20"
                 Background="Transparent"
                 FontSize="24">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Time}" FontSize="16" Opacity="0.7"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <Button Content="Načíst"
                Click="Load_Click"
                BorderThickness="5"
                BorderBrush="Black"
                Background="Transparent"
                HorizontalAlignment="Left"
                Margin="625,343,0,0"
                VerticalAlignment="Top"
                Height="57"
                Width="144"
                FontSize="22"
                FontWeight="Bold"
                FontFamily="Gill Sans Ultra Bold"/>

        <Button Content="Smazat"
                Click="Delete_Click"
                BorderThickness="5"
                BorderBrush="Black"
                Background="Transparent"
                HorizontalAlignment="Left"
                Margin="200,343,0,0"
                VerticalAlignment="Top"
                Height="57"
                Width="144"
                FontSize="22"
                FontWeight="Bold"
                FontFamily="Gill Sans Ultra Bold"/>

        <Button Content="Zavřít"
                Click="Close_Click"
                BorderThickness="5"
                BorderBrush="Black"
                Background="Transparent"
                HorizontalAlignment="Left"
                Margin="20,343,0,0"
                VerticalAlignment="Top"
                Height="57"
                Width="144"
                FontSize="22"
                FontWeight="Bold"
                FontFamily="Gill Sans Ultra Bold"/>

    </Grid>
</Window>