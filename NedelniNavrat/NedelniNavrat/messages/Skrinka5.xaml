<Window x:Class="NedelniNavrat.messages.Skrinka5"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NedelniNavrat.messages"
        mc:Ignorable="d"
        Title="Skrinka5" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>

        <Image Source="/img/pozadi_popup.jpg"
           Stretch="UniformToFill"
           Panel.ZIndex="0"/>

        <TextBlock HorizontalAlignment="Center"
               TextWrapping="Wrap"
               VerticalAlignment="Top"
               FontSize="40"
               FontWeight="Bold"
               FontFamily="Gill Sans Ultra Bold"
               Height="266"
               Width="650"
               Margin="0,53,0,0">
        <Run Text="Našli jste:"/>
        <LineBreak/>
        <Run Text="sedm balíčků instantních nudlí."/>
        <LineBreak/>
        <Run Text="To už přestává být náhoda."/>
        </TextBlock>

        <Button Content="OK"
            Click="Close"
            BorderThickness="5"
            BorderBrush="Black"
            Background="Transparent"
            HorizontalAlignment="Left"
            Margin="625,343,0,0"
            VerticalAlignment="Top"
            Height="57"
            Width="144"
            FontSize="22"
            FontWeight="Bold"
            FontFamily="Gill Sans Ultra Bold"/>

    </Grid>
</Window>
