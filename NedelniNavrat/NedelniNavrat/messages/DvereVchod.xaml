<Window x:Class="NedelniNavrat.messages.DvereVchod"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NedelniNavrat.messages"
        mc:Ignorable="d"
        Title="DvereVchod" Height="450" Width="800"
                       WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/img/pozadi_popup.jpg"
                Stretch="UniformToFill"
                Panel.ZIndex="0"/>
        <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="Zadej kód" VerticalAlignment="Top" FontSize="72" FontWeight="Bold" FontFamily="Gill Sans Ultra Bold" Height="141" Width="464" Margin="164,34,0,0" RenderTransformOrigin="0.551,0.717"/>
        <Button Content="OK" Click="Send" BorderThickness="5" BorderBrush="Black" Background="Transparent" HorizontalAlignment="Left" Margin="625,343,0,0" VerticalAlignment="Top" Height="57" Width="144" FontSize="22" FontWeight="Bold" FontFamily="Gill Sans Ultra Bold"/>
        <TextBox Name="Passwd" HorizontalAlignment="Center" Margin="0,180,0,0" TextWrapping="Wrap" Text="X X X" VerticalAlignment="Top" Width="184" Height="87" FontSize="72"/>
        <Button Content="Close" Click="Close" BorderThickness="5" BorderBrush="Black" Background="Transparent" HorizontalAlignment="Left" Margin="35,343,0,0" VerticalAlignment="Top" Height="57" Width="144" FontSize="22" FontWeight="Bold" FontFamily="Gill Sans Ultra Bold"/>
    </Grid>
</Window>
