<Window x:Class="NedelniNavrat.messages.SaveName"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NedelniNavrat.messages"
        mc:Ignorable="d"
        Title="SaveName" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/img/pozadi_popup.jpg"
                Stretch="UniformToFill"
                Panel.ZIndex="0"/>
        <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="Zadejte název uložení:" VerticalAlignment="Center" FontSize="36" FontWeight="Bold" FontFamily="Gill Sans Ultra Bold" Height="65" Width="522" Margin="26,0,0,0" RenderTransformOrigin="0.551,0.717"/>
        <Button Content="OK" Click="Save" BorderThickness="5" BorderBrush="Black" Background="Transparent" HorizontalAlignment="Left" Margin="625,343,0,0" VerticalAlignment="Top" Height="57" Width="144" FontSize="22" FontWeight="Bold" FontFamily="Gill Sans Ultra Bold"/>
        <TextBox Name="Potrvdit" HorizontalAlignment="Left" Margin="548,167,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="221" Height="83" FontSize="48"/>
        <Button Content="Close" Click="Close" BorderThickness="5" BorderBrush="Black" Background="Transparent" HorizontalAlignment="Left" Margin="26,343,0,0" VerticalAlignment="Top" Height="57" Width="144" FontSize="22" FontWeight="Bold" FontFamily="Gill Sans Ultra Bold"/>
    </Grid>
</Window>
